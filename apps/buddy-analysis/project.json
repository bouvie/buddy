{
  "name": "buddy-analysis",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/buddy-analysis/src",
  "projectType": "application",
  "tags": ["type:app-analysis", "scope:analysis"],
  "implicitDependencies": ["rules-engine", "event-bus", "telemetry-events", "notification-contracts", "telemetry-data-access"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/buddy-analysis"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "buddy-analysis:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": { "buildTarget": "buddy-analysis:build:development" },
        "production":  { "buildTarget": "buddy-analysis:build:production" }
      }
    }
  }
}
