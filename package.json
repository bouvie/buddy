{
  "name": "buddy",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "scripts": {
    "start": "nx serve buddy-frontend",
    "start:api": "nx serve buddy-api",
    "start:ingest": "nx serve buddy-ingest",
    "start:analysis": "nx serve buddy-analysis",
    "build": "nx build buddy-frontend",
    "build:api": "nx build buddy-api",
    "build:ingest": "nx build buddy-ingest",
    "build:analysis": "nx build buddy-analysis",
    "build:all": "nx run-many -t build",
    "build:stack": "nx run-many -t build -p buddy-frontend,buddy-api,buddy-ingest,buddy-analysis --parallel=4",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "ci:build": "nx run-many -t build --parallel=4",
    "ci:test": "nx run-many -t test --parallel=4",
    "ci:lint": "nx run-many -t lint --parallel=4",
    "storybook": "nx storybook ui",
    "build-storybook": "nx build-storybook ui",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "kill": "npx kill-port 4200 3000 3001 3002",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:up:tools": "docker compose -f docker/docker-compose.yml --profile tools up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "dev:backend": "concurrently -n api,ingest,analysis -c blue,cyan,magenta \"npm run start:api\" \"npm run start:ingest\" \"npm run start:analysis\"",
    "dev": "concurrently -n frontend,api,ingest,analysis -c green,blue,cyan,magenta \"npm run start\" \"npm run start:api\" \"npm run start:ingest\" \"npm run start:analysis\"",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "android:sync": "npm run build && npx cap sync android",
    "android:run": "npx cap run android",
    "android:open": "npx cap open android",
    "android:log": "%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb logcat -s Capacitor/Console,chromium",
    "android:dev": "npm run build:stack && npx cap sync android && npx cap run android",
    "ios": "npm run build && npx cap sync ios && npx cap open ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:run": "npx cap run ios",
    "ios:open": "npx cap open ios",
    "ios:dev": "npm run build:stack && npx cap sync ios && npx cap run ios"
  },
