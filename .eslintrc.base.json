{
  "root": true,
  "ignorePatterns": ["**/*"],
  "plugins": ["@nx"],
  "overrides": [
    {
      "files": ["*.ts"],
      "extends": [
        "plugin:@typescript-eslint/recommended",
        "plugin:@nx/typescript"
      ],
      "rules": {
        "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
        "@typescript-eslint/explicit-function-return-type": "off",
        "@typescript-eslint/no-explicit-any": "warn",
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "enforceBuildableLibDependency": true,
            "allow": [],
            "depConstraints": [
              {
                "sourceTag": "scope:monitoring",
                "onlyDependOnLibsWithTags": ["scope:monitoring"]
              },
              {
                "sourceTag": "scope:acquisition",
                "onlyDependOnLibsWithTags": ["scope:acquisition", "scope:events"]
              },
              {
                "sourceTag": "scope:events",
                "onlyDependOnLibsWithTags": ["scope:events"]
              },
              {
                "sourceTag": "scope:analysis",
                "onlyDependOnLibsWithTags": ["scope:analysis", "scope:events"]
              },
              {
                "sourceTag": "type:graphql-client",
                "onlyDependOnLibsWithTags": ["scope:monitoring"]
              },
              {
                "sourceTag": "type:ui",
                "onlyDependOnLibsWithTags": ["scope:monitoring"]
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.html"],
      "extends": ["plugin:@nx/angular-template"],
      "rules": {}
    }
  ]
}
