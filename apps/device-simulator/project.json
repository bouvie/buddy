{
  "name": "device-simulator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/device-simulator/src",
  "projectType": "application",
  "tags": ["type:app-simulator", "scope:acquisition"],
  "implicitDependencies": ["device-contracts"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/device-simulator"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "device-simulator:build",
        "runBuildTargetDependencies": false,
        "port": 9232
      },
      "configurations": {
        "development": { "buildTarget": "device-simulator:build:development" },
        "production":  { "buildTarget": "device-simulator:build:production", "inspect": false }
      }
    }
  }
}
